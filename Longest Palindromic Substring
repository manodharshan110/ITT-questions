Given a string s, return the longest palindromic substring in s.

Example 1:
Input: s = "babad"
Output: "bab"
Explanation: "aba" is also a valid answer.

Example 2:
Input: s = "cbbd"
Output: "bb"
 
Constraints:
1 <= s.length <= 1000
s consist of only digits and English letters.

class Solution {
    public String longestPalindrome(String s) {
        int len=s.length();
        String ans="";
        int l=0;
        for(int i=0;i<len;i++)
        {
            for(int j=i;j<len;j++)
            {
                if(ispalindrome(s,i,j))
                {
                    if(j-i+1>l)
                    {
                      l=j-i+1;
                      ans=s.substring(i,j+1);
                    }
                }
            }
        }
        return ans;
    }
    boolean ispalindrome(String m,int lef,int rig)
    {
        
        while(lef<rig)
        {
            if(m.charAt(lef)!=m.charAt(rig))
            {
                return false;
            }
            else{
            lef++;
            rig--;
            }
        }
        return true;
    }
}
